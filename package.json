{
  "name": "vitesse-electron",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@7.29.1",
  "description": "A Vite + Vue 3 + TypeScript + Electron starter template",
  "author": "cyole <hi@cyoo.cn>",
  "main": "dist-electron/main/index.js",
  "scripts": {
    "build": "vue-tsc --noEmit && electron-builder",
    "dev": "vite --port 3333 --open",
    "lint": "eslint .",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview",
    "up": "taze major -I",
    "postinstall": "npx simple-git-hooks"
  },
  "dependencies": {
    "@vueuse/core": "^9.13.0",
    "vue": "^3.2.47",
    "vue-router": "^4.1.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^0.36.0",
    "@iconify-json/carbon": "^1.1.16",
    "@iconify-json/ion": "^1.1.8",
    "@types/node": "^18.15.3",
    "@unocss/reset": "^0.50.4",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue-macros/volar": "^0.9.0",
    "electron": "^23.1.3",
    "electron-builder": "^23.6.0",
    "eslint": "^8.36.0",
    "lint-staged": "^13.2.0",
    "pnpm": "^7.29.1",
    "simple-git-hooks": "^2.8.1",
    "taze": "^0.9.0",
    "typescript": "^4.9.5",
    "unocss": "^0.50.4",
    "unplugin-auto-import": "^0.15.1",
    "unplugin-vue-components": "^0.24.1",
    "unplugin-vue-macros": "^1.10.0",
    "vite": "^4.1.4",
    "vite-plugin-electron": "^0.11.1",
    "vite-plugin-electron-renderer": "^0.12.1",
    "vite-plugin-pages": "^0.29.0",
    "vue-tsc": "^1.2.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "eslintConfig": {
    "extends": "@antfu",
    "rules": {
      "no-console": "off"
    }
  }
}
